BOT_TOKEN=123456:ABCDEF-your-bot-token

# HTTP server
PORT=8787
BASE_URL=http://localhost:8787

# Render / webhook mode (recommended in production):
# Set to your public URL, e.g. https://your-service.onrender.com
WEBHOOK_URL=

# Storage paths (recommended: Render persistent disk mount)
DATA_DIR=/var/data
STORAGE_DIR=/var/storage

# Security (recommended): comma-separated Telegram chat IDs allowed to upload
# Example: ALLOWED_CHAT_IDS=123456789,987654321
ALLOWED_CHAT_IDS=

# Optional: require an API key for HTTP endpoints (header: X-API-Key: <value>)
API_KEY=

# Optional: max accepted upload size (MB) for Telegram videos/documents (best-effort)
MAX_FILE_MB=2048

